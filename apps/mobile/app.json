{
  "expo": {
    "name": "CoreSet",
    "newArchEnabled": true,
    "slug": "coreset",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coreset",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coreset.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CoreSet uses the camera to analyse your exercise form and count repetitions on-device. No video is stored or transmitted.",
        "NSMicrophoneUsageDescription": "Microphone access is not used.",
        "NSPhotoLibraryUsageDescription": "CoreSet uses your photo library so you can choose a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "CoreSet may save edited profile images to your photo library if you choose to export them."
      }
    },
    "android": {
      "package": "com.coreset.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "./plugins/withSimdjson",
      "./plugins/withMediapipeModel",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0D0D0D"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "CoreSet needs camera access to count your reps on-device.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": true
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "CoreSet uses your photo library so you can choose a profile picture.",
          "cameraPermission": "CoreSet uses your camera so you can take a profile picture.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "newArchEnabled": true
    }
  }
}
