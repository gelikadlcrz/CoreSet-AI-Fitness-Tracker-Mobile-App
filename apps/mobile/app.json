{
  "expo": {
    "name": "CoreSet",
    "slug": "coreset",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "scheme": "coreset",
    "userInterfaceStyle": "dark",
    "splash": {
  "image": "./assets/images/placeholder.png",
  "resizeMode": "contain",
  "backgroundColor": "#0A0A0F"
},
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coreset.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CoreSet uses the camera to analyse your exercise form and count repetitions on-device. No video is stored or transmitted.",
        "NSMicrophoneUsageDescription": "Microphone access is not used."
      }
    },
    "android": {
      "package": "com.coreset.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/app-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
  "expo-router",
  [
    "react-native-vision-camera",
    {
      "cameraPermissionText": "CoreSet needs camera access to count your reps on-device.",
      "enableMicrophonePermission": false
    }
  ],
  [
    "react-native-fast-tflite",
    {
      "enableCoreMLDelegate": true
    }
  ]
  ],
    "experiments": {
      "typedRoutes": true,
      "newArchEnabled": true

    }
  }
}